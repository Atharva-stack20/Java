//Convert km to miles


import java.util.Scanner;
public class KmToMiles {
    public static void main(String[] args){
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter km : ");
        int km = sc.nextInt();
        double miles = km*0.621371;
        System.out.println("Miles = "+miles);
    }
}
